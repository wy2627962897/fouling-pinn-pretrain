# ── LaTeX auxiliary files ──
*.aux
*.log
*.out
*.synctex*
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.spl
*.run.xml
*.bcf

# ── Python cache ──
__pycache__/
*.pyc
*.pyo

# ── Generated PDFs (keep source .tex only) ──
manuscript/*.pdf
drafts/*.pdf

# ── Code output (large/binary, regeneratable) ──
code/output/
!code/output/*.csv
!code/output/*.json

# ── Obsidian metadata ──
.obsidian/
.smart-env/

# ── AI tool outputs ──
.claude/
graphify-out/

# ── Source PDFs (copyright) ──
提取真实数据/*.pdf

# ── Submission artifacts ──
tsep_submission.zip
cover_letter.pdf
title_page.pdf

# ── Temp ──
*.bak
*.swp
*~
